# Supabase 配置（用户认证和数据库）
# 获取方式：https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# 可选：服务端密钥（用于管理员操作，不要在客户端使用）
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Google Analytics（可选）
# 获取方式：https://analytics.google.com → 管理 → 数据流 → 衡量ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Web Search API（资讯自动化，已有）
# WEB_SEARCH_API_KEY=your-api-key
